# Slack (Socket Mode â€” no public URL required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Comma-separated public channel IDs (Câ€¦) â€” only these channels can trigger runs
SLACK_CHANNEL_IDS=C0123456789

# Message must start with this prefix (case-insensitive)
BUILD_PREFIX=build:
STATUS_PREFIX=status:

# Absolute path to the HOST REPO ROOT (the project the agent should edit).
# Default if omitted: parent of tools/ when this package lives at tools/slack-agent-bridge
WORKSPACE_PATH=C:\path\to\your-repo

# Cursor Agent CLI â€” auto-detects %LOCALAPPDATA%\cursor-agent\agent.cmd on Windows
CURSOR_AGENT_BIN=agent
# CURSOR_API_KEY=key_...   # optional if you ran `agent login`

# Extra flags passed to every run (space-separated)
# AGENT_EXTRA_ARGS=--model sonnet

# Prepended to every Slack task â€” customize per host project.
# Tip: point Cursor at CURSOR_INSTALL.md when installing; it will help rewrite this prompt.
AGENT_SYSTEM_PROMPT=Follow AGENTS.md and .cursor/rules. Pipeline: Plan → Build → Test → Push+verify Vercel → Mobile/TestFlight. League Supabase wbwdmxlroniuacibeirg only. Venmo deep-links only. No secrets in git.

# Safety
DRY_RUN=false
AGENT_TIMEOUT_MS=1800000
# Post a "still working" update every 15 minutes
HEARTBEAT_INTERVAL_MS=900000
MAX_SLACK_REPLY_CHARS=3500

# Optional override (default: this package's logs/ folder)
# LOG_DIR=
